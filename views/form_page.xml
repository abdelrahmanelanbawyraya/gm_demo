        <xpath expr="//body" position="inside">
            <div class="survey-container">

                <div style="display: flex; justify-content: space-between; align-items: baseline;">
                    <h1>
                       <i class="fas fa-poll"></i> <t t-esc="survey.name"/>
                    </h1>
                    <div class="subhead">
                        <t t-esc="survey.description or 'We value your feedback — it only takes a minute.'"/>
                    </div>
                </div>

                 <div class="field-grid">

                    <div class="section">
                        <div class="section-title">
                            <i class="fas fa-stethoscope"></i>
                            <span>Questions</span>
                        </div>
                        <form method="POST" t-att-action="'/portal/survey/submit/' + str(survey.id)">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <label t-att-for="lead_ids" class="input-label">
                                <t t-esc="'Select a lead'"/>
                            </label>

                            <select t-att-id="'lead_ids'" 
                                    t-att-name="'lead_ids'" 
                                    class="input-field" 
                                    required="required">
                                <option value="" disabled="disabled" selected="selected">Select a lead...</option>
                                
                                <t t-foreach="available_leads" t-as="lead">
                                    <option t-att-value="lead.id">
                                        <t t-esc="lead.name + ' - ' + lead.phone"/>
                                    </option>
                                </t>
                            </select>

                            <t t-if="questions">
                                 <t t-foreach="questions" t-as="question">
                                    <div class="double-input">
                                        <div class="input-item">
                                            <label  t-att-for="'q-' + str(question.id)" class="input-label">
                                                <t t-esc="question.name"/>
                                            </label>
                                            <input type="text"
                                            t-att-id="'q-' + str(question.id)"
                                            t-att-name="'answer_' + str(question.id)"
                                            class="input-field"
                                            placeholder=" "
                                            required="required"/>

                                            <span class="input-placeholder">Type your answer here...</span>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="empty-state">
                                    <i class="far fa-comment-dots fa-5x mb-4 opacity-50"></i>
                                    <h3>No questions in this survey yet</h3>
                                    <p class="mt-3">Please check back later or contact support.</p>
                                </div>
                            </t>
                            
                            <label t-att-for="state" class="input-label">
                                <t t-esc="'Select the State'"/>
                            </label>

                            <select t-att-id="'state'" 
                                    t-att-name="'state'" 
                                    class="input-field" 
                                    required="required">
                                <option value="" disabled="disabled" selected="selected">Select a State...</option>
                                <option value="p1">Not Answered</option>
                                <option value="p2">Answered but not interested</option>
                                <option value="p3">Answered and request for another time call</option>
                                <option value="d">Completed</option>
                            </select>
                            <div class="feedback-area">
                                <span class="input-label" style="margin-bottom: 10px;">
                                    <i class="fas fa-pen"></i> Enter Your Comments
                                </span>
                                <textarea 
                                    rows="3" 
                                    name="user_comments" 
                                    id="comments"
                                    placeholder="What is your feedback?"
                                ></textarea>
                            </div>
                            <div class="submit-wrapper">
                                <button class="btn">
                                    <i class="fas fa-paper-plane"></i> submit survey
                                </button>

                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>